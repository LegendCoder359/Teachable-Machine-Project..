<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>🕵️‍♂️ GESTURE AGENT: JAZZPUNK SHOWDOWN 🕵️‍♂️</title>
    <link href="https://fonts.googleapis.com/css2?family=Courier+Prime:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
    <style>
        :root {
            --jp-orange: #ff5e00;
            --jp-blue: #00a4e4;
            --jp-yellow: #f1ee1e;
            --jp-pink: #e60067;
            --jp-dark: #12141d;
            --jp-paper: #e9e5d7;
        }

        body {
            font-family: 'Courier Prime', monospace;
            background-color: var(--jp-dark);
            color: var(--jp-paper);
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* Jazzpunk Mid-Century Modern Marquee */
        .marquee-container {
            background-color: var(--jp-orange);
            color: var(--jp-dark);
            padding: 15px 40px;
            transform: rotate(-1.5deg);
            box-shadow: 8px 8px 0px var(--jp-blue);
            margin-bottom: 30px;
            border: 4px solid var(--jp-dark);
        }
        h1 {
            margin: 0;
            font-size: 24px;
            font-weight: 700;
            letter-spacing: -1px;
            text-transform: uppercase;
        }

        .insert-coin-zone {
            background: #1b1e2b;
            border: 3px dashed var(--jp-yellow);
            padding: 15px;
            text-align: center;
            margin-bottom: 25px;
            width: 100%;
            max-width: 900px;
            box-sizing: border-box;
        }

        /* --- CHARACTER SELECTION MATRIX --- */
        .selection-header {
            font-size: 18px;
            color: var(--jp-yellow);
            margin-bottom: 15px;
            text-transform: uppercase;
            font-weight: bold;
        }

        .char-grid {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-bottom: 30px;
            width: 100%;
            max-width: 920px;
            flex-wrap: wrap;
        }

        .char-card {
            background-color: #1b1e2b;
            border: 4px solid #30354a;
            width: 260px;
            padding: 15px;
            cursor: pointer;
            box-sizing: border-box;
            transition: transform 0.1s ease, border-color 0.1s ease;
            position: relative;
        }
        .char-card:hover {
            transform: scale(1.03);
            border-color: var(--jp-paper);
        }
        .char-card.selected {
            border-color: var(--jp-yellow);
            background-color: #252a3d;
            box-shadow: 6px 6px 0px var(--jp-pink);
        }

        .char-name {
            font-size: 16px;
            font-weight: bold;
            margin-bottom: 5px;
            text-transform: uppercase;
        }
        .kirby-color { color: #ff91b4; }
        .mario-color { color: #ff3333; }
        .goryeo-color { color: #8bd34a; }

        .char-archetype {
            font-size: 11px;
            background: #000;
            padding: 2px 6px;
            display: inline-block;
            margin-bottom: 10px;
            border-radius: 3px;
        }

        .char-desc {
            font-size: 11px;
            color: #a0a5bd;
            line-height: 1.4;
            margin-bottom: 10px;
            min-height: 45px;
        }

        .char-stats-preview {
            font-size: 11px;
            border-top: 1px dashed #30354a;
            padding-top: 8px;
            line-height: 1.5;
        }

        /* --- BATTLE SCREEN INTERFACE --- */
        .battle-arena {
            display: none; /* Revealed after setup */
            width: 100%;
            max-width: 920px;
            grid-template-columns: 280px 1fr 280px;
            gap: 20px;
            margin-top: 10px;
        }

        .combat-pod {
            background: #1b1e2b;
            border: 4px solid var(--jp-blue);
            padding: 20px 15px;
            box-sizing: border-box;
            text-align: center;
        }
        .combat-pod.enemy-pod { border-color: var(--jp-pink); }

        .pod-title { font-size: 16px; font-weight: bold; margin-bottom: 15px; text-transform: uppercase;}

        /* Solid Block Retro Meters */
        .meter-container {
            background: #000;
            border: 2px solid var(--jp-paper);
            height: 20px;
            margin-bottom: 8px;
            padding: 2px;
        }
        .meter-fill {
            height: 100%;
            width: 100%;
            background-color: var(--jp-blue);
            transition: width 0.15s linear;
        }
        .enemy-pod .meter-fill { background-color: var(--jp-pink); }

        .hp-text { font-size: 12px; margin-bottom: 15px; color: #a0a5bd;}

        .modifier-badge-list {
            font-size: 11px;
            text-align: left;
            line-height: 1.7;
            background: #0a0c14;
            padding: 10px;
            border-radius: 4px;
        }

        .center-deck {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        #ticker-timer {
            font-size: 14px;
            color: var(--jp-yellow);
            font-weight: bold;
            margin-bottom: 15px;
            text-transform: uppercase;
        }

        #live-gesture-status {
            font-size: 12px;
            background: var(--jp-paper);
            color: var(--jp-dark);
            padding: 8px 12px;
            font-weight: bold;
            margin-bottom: 15px;
            width: 100%;
            box-sizing: border-box;
            text-align: center;
        }

        #camera-viewport canvas {
            border: 4px solid var(--jp-paper);
            background: #000;
            width: 240px !important;
            height: 240px !important;
        }

        .ticker-box {
            background: #0a0c14;
            border: 2px solid #30354a;
            width: 100%;
            height: 120px;
            margin-top: 15px;
            padding: 10px;
            box-sizing: border-box;
            font-size: 11px;
            overflow-y: auto;
            text-align: left;
            line-height: 1.5;
        }

        /* Overlay */
        #game-modal {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(18, 20, 29, 0.95);
            justify-content: center;
            align-items: center;
            flex-direction: column;
            z-index: 100;
        }
        #modal-title { font-size: 32px; color: var(--jp-orange); margin-bottom: 20px; text-transform: uppercase;}
        .retro-btn {
            font-family: 'Courier Prime', monospace;
            background-color: var(--jp-yellow);
            color: var(--jp-dark);
            border: 3px solid var(--jp-dark);
            padding: 10px 25px;
            font-weight: bold;
            font-size: 14px;
            cursor: pointer;
            box-shadow: 4px 4px 0px var(--jp-blue);
        }
        .retro-btn:hover { background-color: #fff; }
    </style>
</head>
<body>

    <div class="marquee-container">
        <h1>SIMULATION MATRIX: GESTURE FIGHTER</h1>
    </div>

    <!-- Diskette Uploader -->
    <div class="insert-coin-zone" id="uploader-crate">
        <label style="display: block; font-size: 12px; margin-bottom: 10px; font-weight: bold; color: var(--jp-orange);">
            LOAD WEBCAM ROM DATASET (.ZIP EXPORT):
        </label>
        <input type="file" id="zip-loader" accept=".zip" />
    </div>

    <!-- SELECTION MATRIX SCREEN -->
    <div id="selection-screen-wrapper" style="display:none; text-align: center; width: 100%;">
        <div class="selection-header">CHOOSE YOUR OPERATIVE</div>
        <div class="char-grid">
            
            <!-- KIRBY: THE BUFFED CHARACTER -->
            <div class="char-card selected" onclick="pickAgent('kirby', this)">
                <div class="char-name kirby-color">KIRBY</div>
                <div class="char-archetype" style="color:var(--jp-blue)">[BUFFED / POWERFUL]</div>
                <div class="char-desc">An pink entity with hyper-elastic parameters. Inhaled data streams amplified its capabilities.</div>
                <div class="char-stats-preview">
                    👍 THUMBS UP: 22 DMG<br>
                    👎 THUMBS DOWN: 50% BLK<br>
                    👉 SIDEWAYS: +14 HEAL
                </div>
            </div>

            <!-- MARIO: THE AVERAGE CHARACTER -->
            <div class="char-card" onclick="pickAgent('mario', this)">
                <div class="char-name mario-color">MARIO</div>
                <div class="char-archetype" style="color:var(--jp-yellow)">[STANDARDIZED BASELINE]</div>
                <div class="char-desc">Plumbing professional displaced inside the network hardware. Fully predictable metrics.</div>
                <div class="char-stats-preview">
                    👍 THUMBS UP: 15 DMG<br>
                    👎 THUMBS DOWN: 50% BLK<br>
                    👉 SIDEWAYS: +14 HEAL
                </div>
            </div>

            <!-- OLD MAN GORYEO: THE NERFED CHARACTER -->
            <div class="char-card" onclick="pickAgent('goryeo', this)">
                <div class="char-name goryeo-color">OLD MAN GORYEO</div>
                <div class="char-archetype" style="color:var(--jp-pink)">[NERFED / HARD MODE]</div>
                <div class="char-desc">An ancient historical epoch compressed into an old civilian frame. Severe latency and joint pain.</div>
                <div class="char-stats-preview">
                    👍 THUMBS UP: 9 DMG<br>
                    👎 THUMBS DOWN: 50% BLK<br>
                    👉 SIDEWAYS: +10 HEAL
                </div>
            </div>

        </div>
        <button class="retro-btn" onclick="lockInSelection()">INITIALIZE FIGHT PROTOCOL</button>
    </div>

    <!-- LIVE CONSOLE STAGE FLIGHT GRID -->
    <div class="battle-arena" id="battle-view">
        
        <!-- Player UI Deck -->
        <div class="combat-pod">
            <div class="pod-title" id="p1-title">AGENT</div>
            <div class="meter-container">
                <div class="meter-fill" id="p1-bar"></div>
            </div>
            <div class="hp-text" id="p1-label">HP: 100/100</div>
            
            <div class="modifier-badge-list" id="p1-perks">
                <!-- Loaded dynamically -->
            </div>
        </div>

        <!-- System Viewport Column -->
        <div class="center-deck">
            <div id="ticker-timer">LOCKING MATRIX...</div>
            <div id="live-gesture-status">WAITING FOR HAND CAPTURE</div>
            <div id="camera-viewport"></div>
            <div class="ticker-box" id="terminal-ticker"></div>
        </div>

        <!-- Enemy UI Deck -->
        <div class="combat-pod enemy-pod">
            <div class="pod-title">SYSTEM BOSS</div>
            <div class="meter-container">
                <div class="meter-fill" id="enemy-bar"></div>
            </div>
            <div class="hp-text" id="enemy-label">HP: 120/120</div>
            
            <div class="modifier-badge-list" style="text-align: center; color:var(--jp-pink);" id="enemy-intent">
                ANALYZING THREAT...
            </div>
        </div>

    </div>

    <!-- Terminal Overlay Screen -->
    <div id="game-modal">
        <div id="modal-title">TERMINATED</div>
        <button class="retro-btn" onclick="resetSimulatedMatch()">REBOOT SIMULATION</button>
    </div>

    <!-- Framework Imports -->
    <script src="https://cdn.jsdelivr.net/npm/@tensorflow/tfjs@latest/dist/tf.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@teachablemachine/image@latest/dist/teachablemachine-image.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>

    <script>
        let model, webcam, maxPredictions;
        let activeGesture = "None";
        let isSimulationRunning = false;

        // Character Roster Profiles
        const roster = {
            kirby: { name: "KIRBY", hp: 110, maxHp: 110, attack: 22, heal: 14, desc: "BUFFED: +Attack, +MaxHP" },
            mario: { name: "MARIO", hp: 100, maxHp: 100, attack: 15, heal: 14, desc: "BALANCED: Factory Specs" },
            goryeo: { name: "OLD MAN GORYEO", hp: 90, maxHp: 90, attack: 9, heal: 10, desc: "NERFED: -Attack, -Heal, -MaxHP" }
        };

        let selectedAgentKey = "kirby"; // Default selection
        
        // Active Fighter Vitals Configuration
        let pHp = 100, pMax = 100;
        let cHp = 120, cMax = 120;
        let cpuNextAction = "Attack";

        // Step Counter Loop Hooks
        let timerTick = 3;
        let cycleThread;

        const fileInput = document.getElementById("zip-loader");
        const globalTimerText = document.getElementById("ticker-timer");
        const liveInputText = document.getElementById("live-gesture-status");
        const matrixOutputBox = document.getElementById("terminal-ticker");

        // Unpack file assets out of memory buffers locally
        fileInput.addEventListener("change", async (e) => {
            const uploadedBlob = e.target.files[0];
            if (!uploadedBlob) return;

            globalTimerText.innerText = "READING DATA SECTOR...";
            const unzipper = new JSZip();

            try {
                const filesystem = await unzipper.loadAsync(uploadedBlob);
                let modelJson, metadataJson, weightsBin;

                for (const filename in filesystem.files) {
                    const node = filesystem.files[filename];
                    if (node.dir) continue;
                    const blobData = await node.async("blob");

                    if (filename.endsWith("model.json")) {
                        modelJson = new File([blobData], "model.json", { type: "application/json" });
                    } else if (filename.endsWith("metadata.json")) {
                        metadataJson = new File([blobData], "metadata.json", { type: "application/json" });
                    } else if (filename.endsWith("weights.bin")) {
                        weightsBin = new File([blobData], "weights.bin", { type: "application/octet-stream" });
                    }
                }

                if (!modelJson || !metadataJson || !weightsBin) {
                    globalTimerText.innerText = "ROM SECTOR PARSE FAULT.";
                    return;
                }

                model = await tmImage.loadFromFiles(modelJson, weightsBin, metadataJson);
                maxPredictions = model.getTotalClasses();

                document.getElementById("uploader-crate").style.display = "none";
                document.getElementById("selection-screen-wrapper").style.display = "block";
                globalTimerText.innerText = "SELECT AGENT MODULE";

            } catch (err) {
                globalTimerText.innerText = "MOUNTING CRASH.";
                console.error(err);
            }
        });

        function pickAgent(key, cardEl) {
            selectedAgentKey = key;
            // Clear prior selection outlines
            document.querySelectorAll('.char-card').forEach(c => c.classList.remove('selected'));
            cardEl.classList.add('selected');
        }

        async function lockInSelection() {
            document.getElementById("selection-screen-wrapper").style.display = "none";
            document.getElementById("battle-view").style.display = "grid";
            globalTimerText.innerText = "BOOTING IMAGE RESOLVER...";

            await bootHardwareCapture();
            resetSimulatedMatch();
        }

        async function bootHardwareCapture() {
            webcam = new tmImage.Webcam(240, 240, true);
            await webcam.setup();
            await webcam.play();
            window.requestAnimationFrame(simulationFrameStep);
            document.getElementById("camera-viewport").appendChild(webcam.canvas);
        }

        async function simulationFrameStep() {
            webcam.update();
            await decipherFrameInputs();
            window.requestAnimationFrame(simulationFrameStep);
        }

        async function decipherFrameInputs() {
            if (!model) return;
            const probabilityLogs = await model.predict(webcam.canvas);
            
            let highVal = 0;
            let leaderTag = "None";

            for (let i = 0; i < maxPredictions; i++) {
                if (probabilityLogs[i].probability > highVal) {
                    highVal = probabilityLogs[i].probability;
                    leaderTag = probabilityLogs[i].className;
                }
            }

            let scrubbedTag = leaderTag.toLowerCase();
            // Maps physical input values directly to action categories requested
            if (scrubbedTag.includes("up") || scrubbedTag.includes("attack")) {
                activeGesture = "THUMBS UP (ATTACK)";
            } else if (scrubbedTag.includes("down") || scrubbedTag.includes("defend") || scrubbedTag.includes("block")) {
                activeGesture = "THUMBS DOWN (BLOCK)";
            } else if (scrubbedTag.includes("side") || scrubbedTag.includes("heal")) {
                activeGesture = "SIDEWAYS THUMB (HEAL)";
            } else {
                activeGesture = "NEUTRAL SIGNAL";
            }

            liveInputText.innerText = `CAPTURE: ${activeGesture}`;
        }

        function triggerCountdownInterval() {
            clearInterval(cycleThread);
            rollCpuStrategy();
            timerTick = 3;
            globalTimerText.innerText = `INTERVAL TICK: ${timerTick}S`;

            cycleThread = setInterval(() => {
                if (!isSimulationRunning) return;
                timerTick--;

                if (timerTick <= 0) {
                    resolveSimulationStep();
                    timerTick = 3;
                }
                globalTimerText.innerText = `INTERVAL TICK: ${timerTick}S`;
            }, 1000);
        }

        function rollCpuStrategy() {
            const logicTree = ["Attack", "Attack", "Defend", "Heal"];
            if (cHp < 60) logicTree.push("Heal", "Defend");
            cpuNextAction = logicTree[Math.floor(Math.random() * logicTree.length)];
            document.getElementById("enemy-intent").innerText = `SYSTEM EXPECTATION:\n-> ${cpuNextAction.toUpperCase()}`;
        }

        // Processing Turn Resolution utilizing the modified active character stats profile
        function resolveSimulationStep() {
            let userAction = activeGesture;
            let activeSpec = roster[selectedAgentKey];

            // Injected dynamic parameters bound strictly to selected layout profiles
            let pStrike = activeSpec.attack;
            let pHeal = activeSpec.heal;
            
            let cStrike = 16;
            let cHeal = 10;

            let pDefenseReduction = 1.0; // 100% incoming damage modifier
            let cDefenseReduction = 1.0;

            pushTerminalLine(`[PULSE RESOLUTION]`);
            pushTerminalLine(`YOU USED: ${userAction}`);
            pushTerminalLine(`CPU USED: ${cpuNextAction.toUpperCase()}`);

            // Apply block mitigation ratios (50% incoming damage reduction configured)
            if (userAction === "THUMBS DOWN (BLOCK)") pDefenseReduction = 0.5;
            if (cpuNextAction === "Defend") cDefenseReduction = 0.5;

            // Compute User Outputs
            if (userAction === "THUMBS UP (ATTACK)") {
                let resultingDamage = Math.floor(pStrike * cDefenseReduction);
                cHp -= resultingDamage;
                pushTerminalLine(`>> Target suffered ${resultingDamage} structural hitpoints loss.`);
            } else if (userAction === "SIDEWAYS THUMB (HEAL)") {
                pHp = Math.min(pMax, pHp + pHeal);
                pushTerminalLine(`>> Re-routed +${pHeal} validation parameters to Operative.`);
            } else if (userAction === "NEUTRAL SIGNAL") {
                pushTerminalLine(`>> STALL WARNING: No operational command mapped.`);
            }

            // Compute Enemy Outputs
            if (cpuNextAction === "Attack") {
                let resultingDamage = Math.floor(cStrike * pDefenseReduction);
                pHp -= resultingDamage;
                pushTerminalLine(`>> System grid struck you for ${resultingDamage} structural loss.`);
            } else if (cpuNextAction === "Heal") {
                cHp = Math.min(cMax, cHp + cHeal);
                pushTerminalLine(`>> System mainframe recovered +${cHeal} buffer integrity.`);
            }

            if (pHp < 0) pHp = 0;
            if (cHp < 0) cHp = 0;

            syncStatusMeters();
            evaluateSimulationLiveness();

            if (isSimulationRunning) {
                rollCpuStrategy();
            }
        }

        function syncStatusMeters() {
            let pPct = (pHp / pMax) * 100;
            let cPct = (cHp / cMax) * 100;

            document.getElementById("p1-bar").style.width = `${pPct}%`;
            document.getElementById("p1-label").innerText = `INTEGRITY: ${pHp}/${pMax}`;

            document.getElementById("enemy-bar").style.width = `${cPct}%`;
            document.getElementById("enemy-label").innerText = `INTEGRITY: ${cHp}/${cMax}`;
        }

        function pushTerminalLine(str) {
            const line = document.createElement("div");
            line.innerText = str;
            matrixOutputBox.appendChild(line);
            matrixOutputBox.scrollTop = matrixOutputBox.scrollHeight;
        }

        function evaluateSimulationLiveness() {
            if (pHp <= 0 && cHp <= 0) {
                haltSession("MUTUAL DATA PURGE", varName('--jp-yellow'));
            } else if (cHp <= 0) {
                haltSession("MAINBOARD CLEARED / WIN", 'var(--jp-blue)');
            } else if (pHp <= 0) {
                haltSession("AGENT DE-REFFED / LOSS", 'var(--jp-pink)');
            }
        }

        function haltSession(msg, themeColor) {
            isSimulationRunning = false;
            clearInterval(cycleThread);
            
            const pane = document.getElementById("game-modal");
            const caption = document.getElementById("modal-title");
            
            caption.innerText = msg;
            caption.style.color = themeColor;
            pane.style.display = "flex";
        }

        function resetSimulatedMatch() {
            let activeSpec = roster[selectedAgentKey];
            
            // Unpack vitals dynamically matching character specifications
            pHp = activeSpec.hp;
            pMax = activeSpec.maxHp;
            cHp = 120;

            document.getElementById("p1-title").innerText = `1P: ${activeSpec.name}`;
            document.getElementById("p1-perks").innerHTML = `
                <b>MODULE STATS:</b><br>
                👍 THUMBS UP: ${activeSpec.attack} DMG<br>
                👎 THUMBS DOWN: -50% DMG<br>
                👉 SIDEWAYS: +${activeSpec.heal} HP<br><br>
                <i>${activeSpec.desc}</i>
            `;

            matrixOutputBox.innerHTML = "";
            document.getElementById("game-modal").style.display = "none";

            isSimulationRunning = true;
            syncStatusMeters();
            pushTerminalLine("SIMULATION CONNECTED. RUN AGENT_");
            triggerCountdownInterval();
        }
    </script>
</body>
</html>
